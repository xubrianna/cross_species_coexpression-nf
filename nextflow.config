/*
 * Nextflow configuration for cross-species coexpression pipeline
 */

params {
    // Input directories: coexpression matrices from per-species pipelines
    // Expects *_corAggSparse.h5ad files (CellType_StudyID_corAggSparse.h5ad)
    mouse_coexpr_dir = null
    human_coexpr_dir = null

    // Reference files
    ortholog_file = "${projectDir}/data/orthologs/1to1_ortho_genes_DIOPT.tsv"
    mouse_tf_file = "${projectDir}/data/transcription_factors/Mus_musculus_TF.txt"
    human_tf_file = "${projectDir}/data/transcription_factors/Homo_sapiens_TF.txt"
    mouse_gene_mapping = "${projectDir}/data/gene_mapping/mouse_gene_meta.csv"

    // Analysis parameters
    top_k = 200            // K for top-K / bottom-K overlap
    min_datasets = 5       // Minimum datasets in both species for TR comparison
    n_null = 1000          // Number of null iterations for permutation tests

    // Output
    outdir = "${launchDir}/results_${new Date().format('yyyyMMdd_HHmmss')}"

    // Conda environment
    conda_env = "/home/bxu/miniconda3/envs/python"
}

// Process resources
process {
    stageInMode = 'symlink'
    errorStrategy = 'retry'
    maxRetries = 2

    withName: 'EXTRACT_TR_PROFILES' {
        executor = 'slurm'
        cpus = 2
        memory = '16 GB'
        time = '2h'
    }

    withName: 'AGGREGATE_PROFILES' {
        executor = 'slurm'
        cpus = 2
        memory = '16 GB'
        time = '2h'
    }

    withName: 'PROFILE_SIMILARITY' {
        executor = 'slurm'
        cpus = 2
        memory = '16 GB'
        time = '4h'
    }

    withName: 'COMPARE_SPECIES' {
        executor = 'slurm'
        cpus = 4
        memory = '32 GB'
        time = '4h'
    }
}

// Conda configuration
conda {
    enabled = true
    useMamba = false
}

// Cleanup configuration
cleanup = true

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        executor {
            perCpuMemAllocation = false
            submitRateLimit = '5 sec'
        }
    }
}

// Report configuration
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.html"
}
